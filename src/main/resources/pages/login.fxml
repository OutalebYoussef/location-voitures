<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!--
  Split-panel login layout
  Left  : dark hero panel (HBox child, flex ~55%)
  Right : white form panel (HBox child, flex ~45%)
  Root  : HBox filling the full window — set scene size to ~900x560
-->
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LoginController"
      style="-fx-background-color: #0B1628;">

    <!-- ══════════════════════════════════════════
         LEFT — HERO PANEL
    ══════════════════════════════════════════ -->
    <VBox HBox.hgrow="ALWAYS"
          spacing="0"
          style="-fx-background-color: #0B1628; -fx-padding: 36 32 32 36;">

        <!-- Logo row -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 0 0;">

            <StackPane minWidth="38" minHeight="38" maxWidth="38" maxHeight="38"
                       style="-fx-background-color: #1E3A8A;
                              -fx-background-radius: 19;
                              -fx-border-color: #3B82F6;
                              -fx-border-width: 2;
                              -fx-border-radius: 19;">
                <Label text="🚗" style="-fx-font-size: 16px;"/>
            </StackPane>

            <HBox spacing="0" alignment="CENTER_LEFT">
                <Label text="Location "
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Voiture"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
            </HBox>
        </HBox>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS" minHeight="40"/>

        <!-- Hero headline -->
        <VBox spacing="10">
            <Label text="Louez la voiture"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="qui vous va."
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
            <Label text="Trouvez, réservez et profitez de la voiture idéale, où que vous soyez."
                   wrapText="true"
                   maxWidth="300"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.45); -fx-line-spacing: 3;"/>
        </VBox>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Bottom feature badges -->
        <HBox spacing="20" alignment="BOTTOM_LEFT">

            <!-- Badge: Sécurisé -->
            <HBox spacing="9" alignment="CENTER_LEFT">
                <StackPane minWidth="30" minHeight="30" maxWidth="30" maxHeight="30"
                           style="-fx-background-color: rgba(59,130,246,0.15); -fx-background-radius: 7;">
                    <Label text="🛡" style="-fx-font-size: 13px;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Sécurisé"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Réservation 100% sécurisée"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.35);"/>
                </VBox>
            </HBox>

            <!-- Badge: Large choix -->
            <HBox spacing="9" alignment="CENTER_LEFT">
                <StackPane minWidth="30" minHeight="30" maxWidth="30" maxHeight="30"
                           style="-fx-background-color: rgba(59,130,246,0.15); -fx-background-radius: 7;">
                    <Label text="🚘" style="-fx-font-size: 13px;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Large choix"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Un large choix de véhicules"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.35);"/>
                </VBox>
            </HBox>

            <!-- Badge: Partout -->
            <HBox spacing="9" alignment="CENTER_LEFT">
                <StackPane minWidth="30" minHeight="30" maxWidth="30" maxHeight="30"
                           style="-fx-background-color: rgba(59,130,246,0.15); -fx-background-radius: 7;">
                    <Label text="📍" style="-fx-font-size: 13px;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Partout"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Disponible dans plusieurs villes"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.35);"/>
                </VBox>
            </HBox>

        </HBox>

    </VBox>

    <!-- ══════════════════════════════════════════
         RIGHT — FORM PANEL
    ══════════════════════════════════════════ -->
    <VBox alignment="CENTER"
          minWidth="330" maxWidth="330"
          style="-fx-background-color: white;
                 -fx-background-radius: 0 16 16 0;
                 -fx-padding: 40 36 32 36;">

        <!-- Icon avatar -->
        <StackPane minWidth="56" maxWidth="56" minHeight="56" maxHeight="56"
                   style="-fx-background-color: #F1F5F9; -fx-background-radius: 28;">
            <Label text="🚗" style="-fx-font-size: 24px;"/>
        </StackPane>

        <Region minHeight="16"/>

        <!-- Title -->
        <Label text="Bienvenue"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

        <Label text="Connectez-vous à votre compte pour continuer"
               wrapText="true"
               textAlignment="CENTER"
               maxWidth="240"
               style="-fx-font-size: 12.5px; -fx-text-fill: #94A3B8; -fx-text-alignment: center; -fx-padding: 4 0 24 0;"/>

        <!-- Email field -->
        <Label text="Email" maxWidth="Infinity"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 5 2;"/>

        <HBox spacing="0" alignment="CENTER_LEFT" maxWidth="Infinity"
              style="-fx-background-color: #F8FAFC;
                     -fx-border-color: #E2E8F0;
                     -fx-border-width: 1.5;
                     -fx-border-radius: 9;
                     -fx-background-radius: 9;
                     -fx-padding: 0 12 0 12;">
            <Label text="✉" style="-fx-font-size: 14px; -fx-text-fill: #CBD5E1;"/>
            <TextField fx:id="txtUsername"
                       promptText="votre@email.com"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: transparent;
                              -fx-border-width: 0;
                              -fx-font-size: 13.5px;
                              -fx-text-fill: #1E293B;
                              -fx-prompt-text-fill: #CBD5E1;
                              -fx-padding: 10 8;"/>
        </HBox>

        <Region minHeight="14"/>

        <!-- Password field -->
        <Label text="Mot de passe" maxWidth="Infinity"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 5 2;"/>

        <HBox spacing="0" alignment="CENTER_LEFT" maxWidth="Infinity"
              style="-fx-background-color: #F8FAFC;
                     -fx-border-color: #E2E8F0;
                     -fx-border-width: 1.5;
                     -fx-border-radius: 9;
                     -fx-background-radius: 9;
                     -fx-padding: 0 12 0 12;">
            <Label text="🔒" style="-fx-font-size: 13px; -fx-text-fill: #CBD5E1;"/>
            <PasswordField fx:id="txtPassword"
                           promptText="••••••••"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: transparent;
                                  -fx-border-width: 0;
                                  -fx-font-size: 13.5px;
                                  -fx-text-fill: #1E293B;
                                  -fx-prompt-text-fill: #CBD5E1;
                                  -fx-padding: 10 8;"/>
<!--            <Button fx:id="btnTogglePassword"-->
<!--                    text="👁"-->
<!--                    onAction="#togglePasswordVisibility"-->
<!--                    style="-fx-background-color: transparent;-->
<!--                           -fx-border-width: 0;-->
<!--                           -fx-cursor: hand;-->
<!--                           -fx-font-size: 13px;-->
<!--                           -fx-text-fill: #CBD5E1;-->
<!--                           -fx-padding: 0;"/>-->
        </HBox>

        <Region minHeight="12"/>

        <!-- Remember me + forgot -->
<!--        <HBox alignment="CENTER_LEFT" spacing="0" maxWidth="Infinity">-->
<!--            <CheckBox fx:id="chkRemember"-->
<!--                      text="Se souvenir de moi"-->
<!--                      style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>-->
<!--            <Region HBox.hgrow="ALWAYS"/>-->
<!--            <Button text="Mot de passe oublié ?"-->
<!--                    onAction="#ouvrirResetPassword"-->
<!--                    style="-fx-background-color: transparent;-->
<!--                           -fx-border-width: 0;-->
<!--                           -fx-text-fill: #2563EB;-->
<!--                           -fx-font-size: 12px;-->
<!--                           -fx-font-weight: bold;-->
<!--                           -fx-cursor: hand;-->
<!--                           -fx-padding: 0;"/>-->
<!--        </HBox>-->

        <Region minHeight="20"/>

        <!-- Login button -->
        <Button text="Se connecter  →"
                onAction="#login"
                maxWidth="Infinity"
                style="-fx-background-color: #2563EB;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 9;
                       -fx-padding: 12 0;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.35), 12, 0, 0, 4);"/>

        <Region minHeight="16"/>

        <!-- Divider -->
        <HBox alignment="CENTER" spacing="10" maxWidth="Infinity">
            <Line endX="90" stroke="#F1F5F9" strokeWidth="1"/>
            <Label text="ou" style="-fx-font-size: 12px; -fx-text-fill: #CBD5E1;"/>
            <Line endX="90" stroke="#F1F5F9" strokeWidth="1"/>
        </HBox>

        <Region minHeight="16"/>

        <!-- Google button -->
<!--        <Button text="G   Continuer avec Google"-->
<!--                onAction="#loginWithGoogle"-->
<!--                maxWidth="Infinity"-->
<!--                style="-fx-background-color: white;-->
<!--                       -fx-text-fill: #1E293B;-->
<!--                       -fx-font-size: 13px;-->
<!--                       -fx-font-weight: 500;-->
<!--                       -fx-background-radius: 9;-->
<!--                       -fx-border-color: #E2E8F0;-->
<!--                       -fx-border-width: 1.5;-->
<!--                       -fx-border-radius: 9;-->
<!--                       -fx-padding: 10 0;-->
<!--                       -fx-cursor: hand;"/>-->

        <Region minHeight="20"/>

        <!-- Sign up row -->
<!--        <HBox alignment="CENTER" spacing="4">-->
<!--            <Label text="Pas encore de compte ?"-->
<!--                   style="-fx-font-size: 12.5px; -fx-text-fill: #94A3B8;"/>-->
<!--            <Button text="S'inscrire"-->
<!--                    onAction="#ouvrirInscription"-->
<!--                    style="-fx-background-color: transparent;-->
<!--                           -fx-border-width: 0;-->
<!--                           -fx-text-fill: #2563EB;-->
<!--                           -fx-font-size: 12.5px;-->
<!--                           -fx-font-weight: bold;-->
<!--                           -fx-cursor: hand;-->
<!--                           -fx-padding: 0;"/>-->
<!--        </HBox>-->

        <!-- Error label -->
        <Label fx:id="lblError"
               text=""
               maxWidth="Infinity"
               wrapText="true"
               style="-fx-font-size: 12px; -fx-text-fill: #EF4444; -fx-padding: 8 0 0 0; -fx-alignment: center;"/>

    </VBox>

</HBox>

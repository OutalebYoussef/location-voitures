<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>


<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.RegisterController"
      style="-fx-background-color: #0B1628;">

    <!-- ══════════════════════════════════════════
         LEFT — HERO PANEL
    ══════════════════════════════════════════ -->
    <VBox HBox.hgrow="ALWAYS"
          spacing="0"
          style="-fx-background-color: #0B1628; -fx-padding: 36 32 32 36;">

        <!-- Logo row -->
        <HBox fx:id="logoBox"
              alignment="CENTER_LEFT"
              spacing="10"
              onMouseClicked="#goToHome"
              style="-fx-cursor: hand;">

            <ImageView fitWidth="100"
                       fitHeight="100"
                       preserveRatio="true">

                <image>
                    <Image url="@/images/logo.png"/>
                </image>

            </ImageView>

            <HBox spacing="0" alignment="CENTER_LEFT">
                <Label text="Location "
                       style="-fx-font-size:16px;
                      -fx-font-weight:bold;
                      -fx-text-fill:white;"/>

                <Label text="Voiture"
                       style="-fx-font-size:16px;
                      -fx-font-weight:bold;
                      -fx-text-fill:#3B82F6;"/>
            </HBox>

        </HBox>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS" minHeight="40"/>

        <!-- Hero headline -->
        <VBox spacing="10">
            <Label text="Louez la voiture"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="qui vous va."
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
            <Label text="Trouvez, réservez et profitez de la voiture idéale, où que vous soyez."
                   wrapText="true"
                   maxWidth="300"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.45); -fx-line-spacing: 3;"/>
        </VBox>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS"/>

        <!-- Bottom feature badges -->
        <HBox spacing="20" alignment="BOTTOM_LEFT">

            <!-- Badge: Sécurisé -->
            <HBox spacing="9" alignment="CENTER_LEFT">
                <StackPane minWidth="30" minHeight="30" maxWidth="30" maxHeight="30"
                           style="-fx-background-color: rgba(59,130,246,0.15); -fx-background-radius: 7;">
                    <Label text="🛡" style="-fx-font-size: 13px;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Sécurisé"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Réservation 100% sécurisée"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.35);"/>
                </VBox>
            </HBox>

            <!-- Badge: Large choix -->
            <HBox spacing="9" alignment="CENTER_LEFT">
                <StackPane minWidth="30" minHeight="30" maxWidth="30" maxHeight="30"
                           style="-fx-background-color: rgba(59,130,246,0.15); -fx-background-radius: 7;">
                    <Label text="🚘" style="-fx-font-size: 13px;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Large choix"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Un large choix de véhicules"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.35);"/>
                </VBox>
            </HBox>

            <!-- Badge: Partout -->
            <HBox spacing="9" alignment="CENTER_LEFT">
                <StackPane minWidth="30" minHeight="30" maxWidth="30" maxHeight="30"
                           style="-fx-background-color: rgba(59,130,246,0.15); -fx-background-radius: 7;">
                    <Label text="📍" style="-fx-font-size: 13px;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Partout"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    <Label text="Disponible dans plusieurs villes"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.35);"/>
                </VBox>
            </HBox>

        </HBox>

    </VBox>

    <!-- ══════════════════════════════════════════
         RIGHT — FORM PANEL
    ══════════════════════════════════════════ -->

        <VBox spacing="15" alignment="CENTER"
              minWidth="400"
              style="-fx-background-color: white;
                 -fx-background-radius: 0 16 16 0;
                 -fx-padding: 40 36 32 36;">

            <TextField fx:id="txtUsername"
                       promptText="Nom d'utilisateur"/>

            <TextField fx:id="txtEmail"
                       promptText="Email"/>

            <TextField fx:id="txtPhone"
                       promptText="Téléphone"/>

            <PasswordField fx:id="txtPassword"
                           promptText="Mot de passe"/>

            <PasswordField fx:id="txtConfirmPassword"
                           promptText="Confirmer le mot de passe"/>

            <Button text="Créer un compte"
                    onAction="#register"/>

        </VBox>


</HBox>

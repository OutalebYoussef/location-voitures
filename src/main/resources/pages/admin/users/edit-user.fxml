<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<VBox xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.admin.users.EditUserController"
           style="-fx-background-color: #F0F4F8; -fx-padding: 28;">

    <!-- ══════════════════════════════════════════
         CARD
    ══════════════════════════════════════════ -->
    <VBox maxWidth="380"
          style="-fx-background-color: white;
                 -fx-background-radius: 14;
                 -fx-border-color: #E9EEF4;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(15,27,45,0.08), 18, 0, 0, 4);">

        <!-- Card header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 20 26 16 26;
                     -fx-border-color: #F1F5F9;
                     -fx-border-width: 0 0 1 0;">
            <VBox spacing="2">
                <Label text="Modifier l'utilisateur"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label fx:id="lblSubtitle"
                       text="Mettez à jour les informations du compte"
                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>

        <!-- Card body -->
        <VBox spacing="14" style="-fx-padding: 22 26 26 26;">

            <!-- Username -->
            <VBox spacing="6">
                <Label text="Nom d'utilisateur"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <HBox spacing="0" alignment="CENTER_LEFT" maxWidth="Infinity"
                      style="-fx-background-color: #F8FAFC;
                             -fx-border-color: #E2E8F0;
                             -fx-border-width: 1.5;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 0 12;">
                    <Label text="👤" style="-fx-font-size: 13px; -fx-text-fill: #CBD5E1;"/>
                    <TextField fx:id="usernameField"
                               promptText="Nom d'utilisateur"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-width: 0;
                                      -fx-font-size: 13.5px;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;
                                      -fx-padding: 10 8;"/>
                </HBox>
            </VBox>

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Email"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <HBox spacing="0" alignment="CENTER_LEFT" maxWidth="Infinity"
                      style="-fx-background-color: #F8FAFC;
                             -fx-border-color: #E2E8F0;
                             -fx-border-width: 1.5;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 0 12;">
                    <Label text="✉" style="-fx-font-size: 13px; -fx-text-fill: #CBD5E1;"/>
                    <TextField fx:id="emailField"
                               promptText="Email"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-width: 0;
                                      -fx-font-size: 13.5px;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;
                                      -fx-padding: 10 8;"/>
                </HBox>
            </VBox>

            <!-- Phone -->
            <VBox spacing="6">
                <Label text="Téléphone"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <HBox spacing="0" alignment="CENTER_LEFT" maxWidth="Infinity"
                      style="-fx-background-color: #F8FAFC;
                             -fx-border-color: #E2E8F0;
                             -fx-border-width: 1.5;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 0 12;">
                    <Label text="📞" style="-fx-font-size: 12px; -fx-text-fill: #CBD5E1;"/>
                    <TextField fx:id="phoneField"
                               promptText="Téléphone"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-width: 0;
                                      -fx-font-size: 13.5px;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;
                                      -fx-padding: 10 8;"/>
                </HBox>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Mot de passe"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <HBox spacing="0" alignment="CENTER_LEFT" maxWidth="Infinity"
                      style="-fx-background-color: #F8FAFC;
                             -fx-border-color: #E2E8F0;
                             -fx-border-width: 1.5;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 0 12;">
                    <Label text="🔒" style="-fx-font-size: 12px; -fx-text-fill: #CBD5E1;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Laisser vide pour ne pas changer"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-width: 0;
                                          -fx-font-size: 13.5px;
                                          -fx-text-fill: #1E293B;
                                          -fx-prompt-text-fill: #CBD5E1;
                                          -fx-padding: 10 8;"/>
                </HBox>
            </VBox>

            <!-- Role -->
            <VBox spacing="6">
                <Label text="Rôle"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <ComboBox fx:id="roleField"
                          maxWidth="Infinity"
                          style="-fx-font-size: 13.5px;
                                 -fx-background-color: #F8FAFC;
                                 -fx-border-color: #E2E8F0;
                                 -fx-border-width: 1.5;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;
                                 -fx-padding: 4 6;
                                 -fx-text-fill: #1E293B;"/>
            </VBox>

            <Region minHeight="6"/>

            <!-- Submit -->
            <Button text="✓  Enregistrer les modifications"
                    onAction="#save"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1D4ED8;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 9;
                           -fx-padding: 12 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(29,78,216,0.3), 12, 0, 0, 4);"/>

        </VBox>

    </VBox>

</VBox>

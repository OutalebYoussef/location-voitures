<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.admin.reservations.ReservationController"
      spacing="20"
      style="-fx-background-color: #f4f6f9; -fx-padding: 24;">

    <!-- ═══════════════════════════════════════════════
         STAT CARDS ROW
    ═══════════════════════════════════════════════ -->
    <HBox spacing="16">

        <!-- Total Réservations -->
        <VBox spacing="6"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
              HBox.hgrow="ALWAYS"
              maxWidth="1.7976931348623157E308">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <!-- Blue icon badge -->
                <VBox alignment="CENTER"
                      minWidth="46" minHeight="46"
                      style="-fx-background-color: #ebf3fd;
                             -fx-background-radius: 10;">
                    <Label text="📅"
                           style="-fx-font-size: 20;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Total réservations"
                           style="-fx-text-fill: #7f8c9a; -fx-font-size: 12;"/>
                    <Label fx:id="lblTotal"
                           text="0"
                           style="-fx-text-fill: #1a2433; -fx-font-size: 26; -fx-font-weight: bold;"/>
                    <Label text="Toutes réservations"
                           style="-fx-text-fill: #aab4be; -fx-font-size: 11;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Confirmées -->
        <VBox spacing="6"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
              HBox.hgrow="ALWAYS"
              maxWidth="1.7976931348623157E308">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox alignment="CENTER"
                      minWidth="46" minHeight="46"
                      style="-fx-background-color: #e8f8f0;
                             -fx-background-radius: 10;">
                    <Label text="✅"
                           style="-fx-font-size: 20;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Confirmées"
                           style="-fx-text-fill: #7f8c9a; -fx-font-size: 12;"/>
                    <Label fx:id="lblAccepte"
                           text="0"
                           style="-fx-text-fill: #1a2433; -fx-font-size: 26; -fx-font-weight: bold;"/>
                    <Label fx:id="lblAcceptePct"
                           text="0% du total"
                           style="-fx-text-fill: #27ae60; -fx-font-size: 11; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- En attente -->
        <VBox spacing="6"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
              HBox.hgrow="ALWAYS"
              maxWidth="1.7976931348623157E308">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox alignment="CENTER"
                      minWidth="46" minHeight="46"
                      style="-fx-background-color: #fef4e5;
                             -fx-background-radius: 10;">
                    <Label text="⏳"
                           style="-fx-font-size: 20;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="En attente"
                           style="-fx-text-fill: #7f8c9a; -fx-font-size: 12;"/>
                    <Label fx:id="lblAttente"
                           text="0"
                           style="-fx-text-fill: #1a2433; -fx-font-size: 26; -fx-font-weight: bold;"/>
                    <Label fx:id="lblAttentePct"
                           text="0% du total"
                           style="-fx-text-fill: #f39c12; -fx-font-size: 11; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Refusées / Annulées -->
        <VBox spacing="6"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);"
              HBox.hgrow="ALWAYS"
              maxWidth="1.7976931348623157E308">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox alignment="CENTER"
                      minWidth="46" minHeight="46"
                      style="-fx-background-color: #fdecec;
                             -fx-background-radius: 10;">
                    <Label text="❌"
                           style="-fx-font-size: 20;"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Annulées"
                           style="-fx-text-fill: #7f8c9a; -fx-font-size: 12;"/>
                    <Label fx:id="lblRefuse"
                           text="0"
                           style="-fx-text-fill: #1a2433; -fx-font-size: 26; -fx-font-weight: bold;"/>
                    <Label fx:id="lblRefusePct"
                           text="0% du total"
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 11; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>

    </HBox>

    <!-- ═══════════════════════════════════════════════
         FILTER BAR
    ═══════════════════════════════════════════════ -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white;
                 -fx-background-radius: 10;
                 -fx-padding: 14 18;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 1);">

        <!-- Search field -->
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par client, véhicule, référence..."
                   prefWidth="320"
                   style="-fx-background-color: #f4f6f9;
                          -fx-background-radius: 8;
                          -fx-border-color: transparent;
                          -fx-padding: 8 12;
                          -fx-font-size: 13;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Date range -->
        <Label text="Date du"
               style="-fx-text-fill: #7f8c9a; -fx-font-size: 13;"/>
        <DatePicker fx:id="dateFilter"
                    promptText="Date début"
                    prefWidth="140"
                    style="-fx-background-color: #f4f6f9;
                           -fx-background-radius: 8;
                           -fx-border-color: #dde2e8;
                           -fx-border-radius: 8;"/>
        <Label text="→"
               style="-fx-text-fill: #aab4be; -fx-font-size: 14;"/>
        <DatePicker fx:id="dateFilterFin"
                    promptText="Date fin"
                    prefWidth="140"
                    style="-fx-background-color: #f4f6f9;
                           -fx-background-radius: 8;
                           -fx-border-color: #dde2e8;
                           -fx-border-radius: 8;"/>

        <!-- Status filter -->
        <ComboBox fx:id="statusFilter"
                  promptText="Statut"
                  prefWidth="150"
                  style="-fx-background-color: #f4f6f9;
                         -fx-background-radius: 8;
                         -fx-border-color: #dde2e8;
                         -fx-border-radius: 8;
                         -fx-font-size: 13;"/>

        <!-- Action buttons -->
        <Button text="Filtrer"
                onAction="#filtrer"
                style="-fx-background-color: #3498db;
                       -fx-text-fill: white;
                       -fx-font-size: 13;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 8 18;
                       -fx-cursor: hand;"/>

        <Button text="⟳  Réinitialiser"
                onAction="#resetFilter"
                style="-fx-background-color: #f4f6f9;
                       -fx-text-fill: #555f6d;
                       -fx-font-size: 13;
                       -fx-background-radius: 8;
                       -fx-border-color: #dde2e8;
                       -fx-border-radius: 8;
                       -fx-padding: 8 14;
                       -fx-cursor: hand;"/>

    </HBox>

    <!-- ═══════════════════════════════════════════════
         TABLE
    ═══════════════════════════════════════════════ -->
    <TableView fx:id="tableReservations"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: white;
                      -fx-background-radius: 12;
                      -fx-border-color: transparent;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 1);
                      -fx-table-cell-border-color: #f0f2f5;">

        <columns>

            <TableColumn fx:id="colId"
                         text="Référence"
                         prefWidth="110"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colClient"
                         text="Client"
                         prefWidth="200"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colVoiture"
                         text="Véhicule"
                         prefWidth="190"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colDate"
                         text="Période de location"
                         prefWidth="175"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colJours"
                         text="Jours"
                         prefWidth="70"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colMontant"
                         text="Montant"
                         prefWidth="140"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colStatus"
                         text="Statut"
                         prefWidth="120"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

            <TableColumn fx:id="colAction"
                         text="Actions"
                         prefWidth="110"
                         style="-fx-font-size: 13; -fx-text-fill: #555f6d;"/>

        </columns>

    </TableView>

</VBox>

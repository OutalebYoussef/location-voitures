<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.admin.AdminLayoutController">

    <!-- ══════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════ -->
    <left>
        <VBox spacing="0"
              prefWidth="230"
              style="-fx-background-color: #0F1B2D; -fx-padding: 22 14 18 14;">

            <!-- Brand -->
            <HBox alignment="CENTER" spacing="10"
                  style="-fx-padding: 0 8 18 8;
                         -fx-border-color: rgba(255,255,255,0.07);
                         -fx-border-width: 0 0 1 0;">

                <ImageView fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true">

                    <image>
                        <Image url="@/images/logo-white.png"/>
                    </image>

                </ImageView>
            </HBox>

            <Region minHeight="18"/>

            <!-- Section label -->
            <Label text="MENU"
                   style="-fx-font-size: 10.5px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.3); -fx-padding: 0 10 8 10;"/>

            <!-- Nav items -->
            <Button text="🏠  Tableau de bord"
                    maxWidth="Infinity"
                    onAction="#showDashboard"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.62);
                           -fx-font-size: 13.5px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 10 12;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT;"/>

            <Region minHeight="3"/>

            <Button text="🚘  Voitures"
                    maxWidth="Infinity"
                    onAction="#showVoitures"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.62);
                           -fx-font-size: 13.5px;
                           -fx-font-weight: 500;
                           -fx-background-radius: 8;
                           -fx-padding: 10 12;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT;"/>

            <Region minHeight="3"/>

            <Button text="👥  Utilisateurs"
                    maxWidth="Infinity"
                    onAction="#showUsers"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.62);
                           -fx-font-size: 13.5px;
                           -fx-font-weight: 500;
                           -fx-background-radius: 8;
                           -fx-padding: 10 12;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT;"/>

            <Region minHeight="3"/>

            <Button text="📅  Réservations"
                    maxWidth="Infinity"
                    onAction="#showReservations"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.62);
                           -fx-font-size: 13.5px;
                           -fx-font-weight: 500;
                           -fx-background-radius: 8;
                           -fx-padding: 10 12;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT;"/>

            <!-- Pushes profile + logout to bottom -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Divider -->
            <Region minHeight="1" maxHeight="1"
                    style="-fx-background-color: rgba(255,255,255,0.07);
                           -fx-padding: 0;"/>

            <Region minHeight="10"/>

            <!-- Profile -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 6 10 10 10;">

                <StackPane minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"
                           style="-fx-background-color: #1E3A8A; -fx-background-radius: 16;">
                    <Label text="AD" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #93C5FD;"/>
                </StackPane>

                <VBox spacing="1">
                    <Label text="Admin"
                           style="-fx-font-size: 12.5px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="admin@location.com"
                           style="-fx-font-size: 10.5px; -fx-text-fill: rgba(255,255,255,0.4);"/>
                </VBox>
            </HBox>

            <!-- Logout -->
            <Button text="↪  Déconnexion"
                    maxWidth="Infinity"
                    onAction="#logout"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #FCA5A5;
                           -fx-font-size: 12.5px;
                           -fx-font-weight: 500;
                           -fx-background-radius: 8;
                           -fx-border-color: rgba(252,165,165,0.3);
                           -fx-border-width: 1;
                           -fx-border-radius: 8;
                           -fx-padding: 9 12;
                           -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT;"/>

        </VBox>
    </left>

    <!-- ══════════════════════════════════════════
         CONTENT
    ══════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentPane"
                   style="-fx-background-color: #F0F4F8;
                          -fx-padding: 28 28 28 28;"/>
    </center>

</BorderPane>

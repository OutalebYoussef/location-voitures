<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.StackPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.admin.AdminLayoutController">

    <left>
        <VBox spacing="10"
              prefWidth="200"
              style="-fx-background-color:#2c3e50; -fx-padding:20;">

            <Label text="ADMIN PANEL"
                   style="-fx-text-fill:white; -fx-font-size:18px;"/>

            <Button text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#showDashboard"/>

            <Button text="Voitures"
                    maxWidth="Infinity"
                    onAction="#showVoitures"/>

            <Button text="Users"
                    maxWidth="Infinity"
                    onAction="#showUsers"/>

            <Button text="Réservations"
                    maxWidth="Infinity"
                    onAction="#showReservations"/>

            <Button text="Déconnexion"
                    maxWidth="Infinity"
                    onAction="#logout"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane"
                   VBox.vgrow="ALWAYS"
                   style="
                 -fx-background-color: #F0F4F8;
                 -fx-padding: 28 28 28 28;
               "/>
    </center>

</BorderPane>
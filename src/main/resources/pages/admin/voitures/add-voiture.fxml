<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.admin.voitures.AddVoitureController"
           style="-fx-background-color: #F0F4F8; -fx-padding: 28;">

    <!-- ══════════════════════════════════════════
         CARD
    ══════════════════════════════════════════ -->
    <VBox maxWidth="460"
          style="-fx-background-color: white;
                 -fx-background-radius: 14;
                 -fx-border-color: #E9EEF4;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(15,27,45,0.08), 18, 0, 0, 4);">

        <!-- Card header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 28 18 28;
                     -fx-border-color: #F1F5F9;
                     -fx-border-width: 0 0 1 0;">

            <VBox spacing="2">
                <Label text="Ajouter une voiture"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label text="Remplissez les informations du véhicule"
                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>

        <!-- Card body -->
        <VBox spacing="14" style="-fx-padding: 24 28 28 28;">

            <!-- Row: Marque / Modèle -->
            <HBox spacing="14">

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Marque"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="txtMarque"
                               promptText="ex: BMW"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Modèle"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="txtModele"
                               promptText="ex: Série 5"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

            </HBox>

            <!-- Row: Matricule / Prix -->
            <HBox spacing="14">

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Matricule"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="txtMatricule"
                               promptText="ex: 123456-A-7"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Prix par jour (DH)"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="txtPrix"
                               promptText="ex: 450"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

            </HBox>

            <!-- Statut -->
            <VBox spacing="6">
                <Label text="Statut"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <ComboBox fx:id="cmbStatut"
                          maxWidth="Infinity"
                          style="-fx-font-size: 13.5px;
                                 -fx-background-color: #F8FAFC;
                                 -fx-border-color: #E2E8F0;
                                 -fx-border-width: 1.5;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;
                                 -fx-padding: 4 6;
                                 -fx-text-fill: #1E293B;"/>
            </VBox>

            <!-- Image upload -->
            <VBox spacing="6">
                <Label text="Photo du véhicule"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">

                    <Button text="⬆  Choisir Image"
                            onAction="#chooseImage"
                            style="-fx-background-color: #F1F5F9;
                                   -fx-text-fill: #334155;
                                   -fx-font-size: 12.5px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-border-color: #CBD5E1;
                                   -fx-border-width: 1.5;
                                   -fx-border-style: dashed;
                                   -fx-border-radius: 8;
                                   -fx-padding: 10 16;
                                   -fx-cursor: hand;"/>

                    <Label fx:id="lblImage"
                           text="Aucun fichier sélectionné"
                           style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-style: italic;"/>

                </HBox>
            </VBox>

            <Region minHeight="6"/>

            <!-- Submit -->
            <Button text="＋  Ajouter la voiture"
                    onAction="#ajouterVoiture"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1D4ED8;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 9;
                           -fx-padding: 12 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(29,78,216,0.3), 12, 0, 0, 4);"/>

        </VBox>

    </VBox>

</StackPane>

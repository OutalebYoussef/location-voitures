<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.voitures.VoitureController"
      fx:id="contentPane"
      alignment="CENTER">

    <Label text="Gestion des Voitures"/>

    <Button text="Ajouter Voiture"
            onAction="#addVoiture" styleClass="btn,btn-primary"/>

    <TableView fx:id="tableVoitures" editable="true">

        <columns>

            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colMarque" text="Marque"/>
            <TableColumn fx:id="colModele" text="Modèle"/>
            <TableColumn fx:id="colMatricule" text="Matricule"/>
            <TableColumn fx:id="colPrix" text="Prix/Jour"/>
            <TableColumn fx:id="colImage" text="Image" prefWidth="120"/>
            <TableColumn fx:id="addBy" text="Ajouter par"/>
            <TableColumn fx:id="colStatut" text="Statut"/>
            <TableColumn text="Action" fx:id="editAction"/>
            <TableColumn text="Action" fx:id="delAction"/>

        </columns>

    </TableView>

</VBox>
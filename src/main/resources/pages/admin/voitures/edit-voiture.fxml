<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>

<VBox  xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.admin.voitures.EditVoitureController"
           style="-fx-background-color: #F0F4F8; -fx-padding: 28;">

    <!-- ══════════════════════════════════════════
         CARD
    ══════════════════════════════════════════ -->
    <VBox maxWidth="440"
          style="-fx-background-color: white;
                 -fx-background-radius: 14;
                 -fx-border-color: #E9EEF4;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(15,27,45,0.08), 18, 0, 0, 4);">

        <!-- Card header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 20 28 16 28;
                     -fx-border-color: #F1F5F9;
                     -fx-border-width: 0 0 1 0;">
            <VBox spacing="2">
                <Label text="Modifier la voiture"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label fx:id="lblSubtitle"
                       text="Mettez à jour les informations du véhicule"
                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>

        <!-- Card body -->
        <VBox spacing="14" style="-fx-padding: 22 28 26 28;">

            <!-- Image preview + change button -->
            <VBox alignment="CENTER" spacing="12" style="-fx-padding: 0 0 4 0;">

                <VBox  minWidth="220" minHeight="140" maxWidth="220" maxHeight="140"
                           style="-fx-background-color: linear-gradient(to bottom right, #1E293B, #334155);
                                  -fx-background-radius: 10;
                                  -fx-border-color: #E2E8F0;
                                  -fx-border-width: 1;
                                  -fx-border-radius: 10;">
                    <ImageView fx:id="imagePreview"
                               fitWidth="220"
                               fitHeight="140"
                               preserveRatio="true"/>
                </VBox >

                <Button text="⬆  Changer l'image"
                        onAction="#chooseImage"
                        style="-fx-background-color: #F1F5F9;
                               -fx-text-fill: #334155;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-color: #E2E8F0;
                               -fx-border-width: 1.5;
                               -fx-border-radius: 8;
                               -fx-padding: 8 14;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- Row: Marque / Modèle -->
            <HBox spacing="14">

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Marque"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="marqueField"
                               promptText="Marque"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Modèle"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="modeleField"
                               promptText="Modèle"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

            </HBox>

            <!-- Row: Matricule / Prix -->
            <HBox spacing="14">

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Matricule"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="matriculeField"
                               promptText="Matricule"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <Label text="Prix / Jour (DH)"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="prixField"
                               promptText="Prix/Jour"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
                </VBox>

            </HBox>

            <!-- Statut -->
            <VBox spacing="6">
                <Label text="Statut"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <TextField fx:id="statutField"
                           promptText="Statut"
                           maxWidth="Infinity"
                           style="-fx-font-size: 13.5px;
                                  -fx-background-color: #F8FAFC;
                                  -fx-border-color: #E2E8F0;
                                  -fx-border-width: 1.5;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 10 13;
                                  -fx-text-fill: #1E293B;
                                  -fx-prompt-text-fill: #CBD5E1;"/>
            </VBox>

            <Region minHeight="6"/>

            <!-- Submit -->
            <Button text="✓  Enregistrer les modifications"
                    onAction="#save"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1D4ED8;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 9;
                           -fx-padding: 12 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(29,78,216,0.3), 12, 0, 0, 4);"/>

        </VBox>

    </VBox>

</VBox >

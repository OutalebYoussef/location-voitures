<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.UserDashboardController"
      style="-fx-background-color: #F0F4F8;">

    <!-- ═══════════════════════════════════════════
         NAVBAR
    ═══════════════════════════════════════════ -->
    <HBox fx:id="navbar"
          alignment="CENTER_LEFT"
          spacing="8"
          style="
            -fx-padding: 0 28 0 28;
            -fx-min-height: 64;
            -fx-max-height: 64;
            -fx-background-color: #0F1B2D;
            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 12, 0, 0, 3);
          ">

        <!-- Brand mark -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <!-- Small accent square -->
            <Rectangle width="4" height="28" arcWidth="4" arcHeight="4"
                       fill="#3B82F6"/>

            <Label text="Location des voitures"
                   style="
                     -fx-font-size: 17px;
                     -fx-font-weight: bold;
                     -fx-text-fill: white;
                     -fx-letter-spacing: 0.5px;
                   "/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Nav group -->
        <HBox alignment="CENTER" spacing="4"
              style="
                -fx-background-radius: 10;
                -fx-padding: 5 6 5 6;
              ">

            <Button text="🚗  Voitures"
                    onAction="#ouvrirVoitures"
                    style="
                       -fx-background-color: transparent;
                      -fx-text-fill: white;
                      -fx-font-size: 13px;
                      -fx-font-weight: 600;
                      -fx-background-radius: 7;
                      -fx-padding: 7 16 7 16;
                      -fx-cursor: hand;
                      -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.4), 8, 0, 0, 2);
                    "/>

            <Button text="📋  Mes Réservations"
                    onAction="#ouvrirMesReservations"
                    style="
                      -fx-background-color: transparent;
                      -fx-text-fill: white;
                      -fx-font-size: 13px;
                      -fx-font-weight: 600;
                      -fx-background-radius: 7;
                      -fx-padding: 7 16 7 16;
                      -fx-cursor: hand;
                      -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.4), 8, 0, 0, 2);
                    "/>

        </HBox>

        <Region minWidth="20"/>

        <Button text="Déconnexion"
                onAction="#logout"
                style="
                  -fx-background-color: transparent;
                  -fx-text-fill: #FDA4AF;
                  -fx-font-size: 12.5px;
                  -fx-font-weight: 500;
                  -fx-background-radius: 7;
                  -fx-border-color: rgba(253,164,175,0.45);
                  -fx-border-width: 1;
                  -fx-border-radius: 7;
                  -fx-padding: 6 14 6 14;
                  -fx-cursor: hand;
                "/>

    </HBox>

    <!-- ═══════════════════════════════════════════
         CONTENT AREA
    ═══════════════════════════════════════════ -->
    <StackPane fx:id="content"
               VBox.vgrow="ALWAYS"
               style="
                 -fx-background-color: #F0F4F8;
                 -fx-padding: 28 28 28 28;
               "/>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.user.reservations.ReservationController"
      style="-fx-background-color: #F0F4F8; -fx-padding: 28;">

    <VBox maxWidth="440"
          style="-fx-background-color: white;
                 -fx-background-radius: 14;
                 -fx-border-color: #E9EEF4;
                 -fx-border-width: 1;
                 -fx-border-radius: 14;
                 -fx-effect: dropshadow(gaussian, rgba(15,27,45,0.08), 18, 0, 0, 4);">

        <!-- Card header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 28 18 28;
                     -fx-border-color: #F1F5F9;
                     -fx-border-width: 0 0 1 0;">

            <VBox spacing="2">
                <Label text="Nouvelle réservation"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label text="Remplissez les informations du véhicule"
                       style="-fx-font-size: 12px; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>

        <VBox spacing="14" style="-fx-padding: 22 28 26 28;">

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Date debut"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <DatePicker fx:id="dateDebut"
                            maxWidth="Infinity"
                            style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
            </VBox>

            <VBox spacing="6" maxWidth="Infinity">
                <Label text="Nombre de jours"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 0 2;"/>
                <TextField fx:id="nbJourField"
                           promptText="Nombre de jours"
                           maxWidth="Infinity"
                           style="-fx-font-size: 13.5px;
                                      -fx-background-color: #F8FAFC;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-width: 1.5;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10 13;
                                      -fx-text-fill: #1E293B;
                                      -fx-prompt-text-fill: #CBD5E1;"/>
            </VBox>

            <Label fx:id="prixJourLabel"/>

            <Label fx:id="prixTotalLabel"
                   text="Total : 0 DH"
                   style="-fx-font-size:18px;-fx-font-weight:bold;"/>

            <Button text="Confirmer"
                    onAction="#confirmer"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1D4ED8;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 9;
                           -fx-padding: 12 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(29,78,216,0.3), 12, 0, 0, 4);"/>

        </VBox>
    </VBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.user.reservations.ReservationController"
      spacing="15"
      alignment="CENTER">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Nouvelle réservation"
           style="-fx-font-size:20px;-fx-font-weight:bold;"/>

    <DatePicker fx:id="dateDebut"/>

    <TextField fx:id="nbJourField"
               promptText="Nombre de jours"/>

    <Label fx:id="prixJourLabel"/>

    <Label fx:id="prixTotalLabel"
           text="Total : 0 DH"
           style="-fx-font-size:18px;-fx-font-weight:bold;"/>

    <Button text="Confirmer"
            onAction="#confirmer"/>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.guest.CarCardController"
      spacing="12"
      prefWidth="260"
      maxWidth="260"
      style="-fx-background-color:white;
             -fx-background-radius:14;
             -fx-border-color:#E5E7EB;
             -fx-border-radius:14;
             -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.12), 10,0,0,3);">

    <ImageView fx:id="imgCar"
               fitWidth="260"
               fitHeight="150"
               preserveRatio="false"/>

    <VBox spacing="8" style="-fx-padding:15;">

        <Label fx:id="lblMarque"
               style="-fx-font-size:18;
                      -fx-font-weight:bold;
                      -fx-text-fill:#1E293B;"/>


        <HBox spacing="5">
            <Label text="Prix :"
                   style="-fx-font-weight:bold;"/>
            <Label fx:id="lblPrix"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Button fx:id="btnReserve"
                text="Réserver"
                maxWidth="Infinity"
                style="-fx-background-color:#2563EB;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;
                       -fx-background-radius:8;
                       -fx-cursor:hand;"/>

    </VBox>

</VBox>